# Copy to .env — never commit .env

# development | staging | production (production refuses default JWT_SECRET)
ENVIRONMENT=development

# Comma-separated list, or * for all origins (credentials disabled when *)
CORS_ORIGINS=*

# PostgreSQL (sync URL for Alembic; app converts to asyncpg)
# Encode special characters in USER/PASSWORD (e.g. @ in password → %40). DB name is case-sensitive if created quoted (e.g. PillPal).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/PillPal

JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Missed dose: minutes after scheduled time before marking missed (if still pending)
DOSE_GRACE_MINUTES=60

API_V1_PREFIX=/api/v1
